<script>
(function() {
  var btns = document.querySelectorAll(".filter-btn");
  var cards = document.querySelectorAll(".font-card");
  btns.forEach(function(btn) {
    btn.addEventListener("click", function() {
      var cat = this.dataset.cat;
      btns.forEach(function(b) {
        b.className = "filter-btn px-4 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200";
      });
      this.className = "filter-btn px-4 py-1.5 rounded-full text-sm font-medium bg-gray-900 text-white";
      cards.forEach(function(card) {
        if (cat === "all" || card.dataset.cat === cat) {
          card.style.display = "";
        } else {
          card.style.display = "none";
        }
      });
    });
  });
})();
</script>